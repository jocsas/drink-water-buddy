{
  "name": "hydrate-buddy-app",
  "version": "0.1.0",
  "description": "A small desktop companion for hydration reminders.",
  "author": "jocsa",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/jocsas/drink-water-buddy.git"
  },
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "node scripts/dev.mjs",
    "dist": "npm run dist:mac",
    "dist:mac": "npm run dist:mac:arm64",
    "dist:mac:dev": "CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac dmg zip",
    "dist:mac:arm64": "CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac dmg zip --arm64 && node scripts/verify-mac-menu-bar.mjs",
    "dist:mac:universal": "CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac dmg zip --universal && node scripts/verify-mac-menu-bar.mjs",
    "dist:mac:friends": "npm run dist:mac:arm64",
    "dist:mac:friends:m4": "npm run dist:mac:arm64",
    "dist:mac:friends:universal": "npm run dist:mac:universal",
    "dist:win": "electron-builder --win nsis"
  },
  "keywords": [
    "electron",
    "desktop-pet",
    "water-reminder",
    "hydration",
    "pixel-art"
  ],
  "license": "MIT",
  "devDependencies": {
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.local.hydratebuddy",
    "productName": "Hydrate Buddy",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "main.js",
      "preload.js",
      "shared/**/*",
      "renderer/**/*",
      "assets/themes/**/*"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.png"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "build/icon.png",
      "category": "public.app-category.healthcare-fitness",
      "artifactName": "HydrateBuddy-${version}-${arch}.${ext}",
      "identity": null,
      "forceCodeSigning": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.inherit.plist",
      "extendInfo": {
        "LSUIElement": true
      }
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Hydrate Buddy",
      "artifactName": "HydrateBuddy-Setup-${version}.${ext}"
    }
  },
  "allowScripts": {
    "electron-winstaller": false
  }
}
